{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "outDir": "./app/assets/builds",
    "rootDir": "./app/javascript",
    "declaration": true,
    "sourceMap": true,
    "skipLibCheck": true
  },
  "include": ["app/javascript/**/*"],
  "exclude": ["node_modules"]
}