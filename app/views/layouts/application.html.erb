    }

    html[data-theme="achromatopsia-light"] {
      --bg: #f5f5f5;
      --bg-panel: # ebebeb;
      --bg-surface: #d5d5d5;
      --fg: #111111;
      --fg-muted: #888888;
      --accent-pink: #000000;
      --accent-cyan: #222222;
      --accent-yellow: #555555;
      --accent-purple: #444444;
      --accent-green: #333333;
      --accent-orange: #555555;
