    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg);
      color: var(--fg);
      font-family: var(--font-ui);
      font-size: var(--font-size);
      height: 100dvh;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    #app-shell {
      display: grid;
      grid-template-rows: auto 1fr auto;
      grid-template-columns: 240px 1fr;
      height: 100dvh;
    }

    #topbar {
      grid-column: 1 / -1;
      background: var(--bg-panel);
      border-bottom: 1px solid var(--accent-pink);
      padding: 0 1rem;
      height: 42px;
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    #topbar button {
      background: none;
      border: none;
      color: var(--fg-muted);
      cursor: pointer;
      font-size: 1.1rem;
      padding: 0.25rem 0.5rem;
      border-radius: 4px;
      margin-left: auto;
      transition: color 0.2s;
    }

    #topbar button:hover {
      color: var(--accent-cyan);
    }

    #topbar .logo {
      font-family: var(--font-mono);
      color: var(--accent-pink);
      font-weight: bold;
      text-shadow: 0 0 8px var(--accent-pink);
      letter-spacing: 0.1em;
    }

    #sidebar {
      background: var(--bg-panel);
      border-right: 1px solid var(--border);
      overflow-y: auto;
      padding: 0.5rem;
    }

    #editor-host {
      overflow: hidden;
      background: var(--bg);
      height: 100%;
      min-height: 0;
    }

    #editor-host .cm-editor {
      height: 100%;
    }

    #statusbar {
      grid-column: 1 / -1;
      background: var(--bg-panel);
      border-top: 1px solid var(--border);
      padding: 0 1rem;
      height: 28px;
      display: flex;
      align-items: center;
      gap: 1rem;
      font-size: 11px;
      color: var(--fg-muted);
    }

    [data-dyslexia="true"] {
      --font-mono: 'OpenDyslexicMono', monospace;
      --font-ui:   'OpenDyslexic', sans-serif;
      letter-spacing: 0.05em;
      word-spacing: 0.1em;
      line-height: 1.8;
    }

    .sidebar-header {
      padding: 0.5rem;
      border-bottom: 1px solid var(--border);
      margin-bottom: 0.5rem;
    }

    .btn-new {
      width: 100%;
      background: transparent;
      border: 1px solid var(--accent-cyan);
      color: var(--accent-cyan);
      padding: 0.25rem 0.5rem;
      border-radius: var(--radius);
      cursor: pointer;
      font-family: var(--font-mono);
      font-size: 12px;
    }

    .btn-new:hover {
      background: var(--accent-cyan);
      color: var(--bg);
    }

    .file-list {
      list-style: none;
      padding: 0;
    }

    .file-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.3rem 0.5rem;
      border-radius: var(--radius);
      cursor: pointer;
      font-size: 12px;
      font-family: var(--font-mono);
    }

    .file-item:hover {
      background: var(--bg-surface);
    }

    .file-item.active {
      background: var(--bg-surface);
      color: var(--accent-cyan);
      border-left: 2px solid var(--accent-cyan);
    }

    .file-name {
      flex: 1;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .btn-delete {
      background: transparent;
      border: none;
      color: var(--fg-muted);
      cursor: pointer;
      font-size: 14px;
      padding: 0 0.25rem;
      opacity: 0;
    }

    .file-item:hover .btn-delete {
      opacity: 1;
    }

    .btn-delete:hover {
      color: var(--accent-pink);
    }
  </style>

  <%= javascript_include_tag "application", defer: true %>
</head>
<body>
  <p class="notice"><%= notice %></p>
  <p class="alert"><%= alert %></p>
  <%= yield %>
</body>
</html>